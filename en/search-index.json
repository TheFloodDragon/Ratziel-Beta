1.95,8,1.95]],["t/41",[2,1.198,4,1.198,9,1.198]],["t/43",[5,1.45,6,1.45]],["t/45",[9,1.45,10,1.95]],["t/49",[11,1.95,12,1.95]],["t/51",[13,2.471]]],"invertedIndex":[["nbt",{"_index":2,"t":{"35":{"position":[[0,3]]},"41":{"position":[[0,3]]}}}],["一般",{"_index":5,"t":{"37":{"position":[[0,2]]},"43":{"position":[[0,2]]}}}],["值",{"_index":9,"t":{"41":{"position":[[3,1]]},"45":{"position":[[0,1]]}}}],["判断",{"_index":8,"t":{"39":{"position":[[2,2]]}}}],["功能",{"_index":0,"t":{"29":{"position":[[0,2]]}}}],["实际",{"_index":7,"t":{"39":{"position":[[0,2]]}}}],["形式",{"_index":6,"t":{"37":{"position":[[2,2]]},"43":{"position":[[2,2]]}}}],["支持",{"_index":11,"t":{"49":{"position":[[0,2]]}}}],["示例",{"_index":13,"t":{"51":{"position":[[0,2]]}}}],["简介",{"_index":1,"t":{"33":{"position":[[0,2]]}}}],["类型",{"_index":10,"t":{"45":{"position":[[2,2]]}}}],["节点",{"_index":3,"t":{"35":{"position":[[3,2]]}}}],["表达式",{"_index":4,"t":{"35":{"position":[[5,3]]},"41":{"position":[[4,3]]}}}],["语言",{"_index":12,"t":{"49":{"position":[[3,2]]}}}]],"pipeline":["stemmer"]}},{"documents":[{"i":28,"t":"基于Taboolib开发的一个多功能插件。","s":"介绍","u":"/Ratziel-Beta/en/docs/about","h":"","p":27},{"i":30,"t":"物品引擎","s":"功能","u":"/Ratziel-Beta/en/docs/about","h":"#功能","p":27},{"i":32,"t":"在对物品的NBT标签进行操作时, 就会用到NBT表达式","s":"NBT表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"","p":31},{"i":34,"t":"NBT表达式分为两种: NBT节点表达式 NBT值表达式 顾名思义，对NBT标签的编辑，既需要知道在哪修改，也需要知道修改成什么。","s":"简介","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#简介","p":31},{"i":36,"t":"NBT的节点其实就是指定在哪修改","s":"NBT节点表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#nbt节点表达式","p":31},{"i":38,"t":"浅层节点: 节点名 形如 Damage CustomModelData 的是浅层节点，也就是只有一层。 深层节点: 节点I.节点II 形如 display.Name display.Name 的是深层节点。 深层节点有很多层，每层之间以 . 分割。 列表元素节点: 节点名[0] 形如 TestList[0] Enchantments[1] 的是列表元素节点。 节点名末尾以 [数字] 的形式，其中数字代表的是该列表中的元素索引。 若有一个名为 AWA 的列表 [ \"a\", \"b\", \"c\" ] 则 AWA[0] 表示列表中的第一个元素 a (没错，索引是从0开始的)","s":"一般形式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#一般形式","p":31},{"i":40,"t":"假定有这样一串NBT: Vacation: Duration: - \"5 ~ 7\" - from: \"2024/1/5\" to: \"2024/1/7\" 其中 Vacation 就是节点名，因为上面没有别的节点了，所以它是所有节点里最大的，是浅层节点。 而 Duration 则不一样，它隶属于 Vacation，是深层节点，在第二层位置，表示为 Vacation.Duration 再看 Duration 其实是个列表，第一个元素是 \"5 ~ 7\"，它的索引位置是 0 ，引用它，就需要这样的表达式 Vacation.Duration[0] 而 Duration 的第二个元素是复合的，要引用它的 from 或 to ，我们需要使用 Vacation.Duration[1].from 或者 Vacation.Duration[1].to 我们可以分别得到 \"2024/1/5\" 和 \"2024/1/7\"","s":"实际判断","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#实际判断","p":31},{"i":42,"t":"NBT的值其实就是修改成什么","s":"NBT值表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#nbt值表达式","p":31},{"i":44,"t":"一种是直接写 如 爱死你了 ，会被解析成 NBTString 类型 再如 114514 ， 会被解析成 NBTInt 类型 另一种是精确写法(精确指定类型) 精确写法必须以 : 开头 一般形式 :{V}{T} ，其中{V}代表值，{T}代表类型代号 对于集合类型，需要用 , 分割集合中的元素，如 1,1,4,5,1,4ba，其中 ba 是集合类型代号，表示 NBTByteArray 对于特殊类型，:cpd 表示 NBTCompound 类型，:list 表示 NBTList 类型 示例: NBTShort - :666s NBTFloat - :2.333f NBTIntArray - 1,2,3,4,5ia","s":"一般形式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#一般形式-1","p":31},{"i":46,"t":"允许以下类型的值 类型 代号 描述 NBTCompound c , cpd, compound 复合类型 NBTList l, list 列表类型 NBTIntArray ia 集合类型 NBTByteArray ba 集合类型 NBTLongArray la 集合类型 NBTString t 字符串 NBTInt i 整形 NBTDouble d Double NBTByte b Byte NBTLong l Long NBTFloat f Float NBTShort s Short","s":"值的类型","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#值的类型","p":31},{"i":48,"t":"目前仅为设想","s":"聚合脚本语言 - ASL (Aggregate scripting language)","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"","p":47},{"i":50,"t":"MScript - 艾乐 Kether - Taboolib (实际使用的库) JavaScript - Nashorn","s":"支持的语言","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"#支持的语言","p":47},{"i":52,"t":"Example1: - $M: var a = 1 #切换到MScript,定义变量 - var b = 2 - def add(){return a + b;} # 定义函数 - $J: val out = FPool.add(); #JavaScript,执行MScript定义函数 - console(out); - $K: print &out #KetherScript，输出变量 - set a to 2 - print invoke \"add\" with [] - $K: |- # 简易表达式 set b to 2 print &b Example2: |- $M: var a = 1 var b = 2 def add(){return a + b;} $J: console(FPool.add()); $K: set a to 2 print invoke \"add\" with [] # 条件语句 Example3: - $M: var a = 6 - $M: var b = 9 - if: a == b # 默认继承上面的脚本语言，即MScript (要返回布尔值) then: a = 6 else: $K set &a to &b # 转换到Kether并且设置，不往父级传承 - try: a = b+114514 #try..catch.. 此时应该还是MScript catch: #类表达式 Test1Expection.class: @IGNORE #忽略 Test2Expection.class: print a; #MScript - if: $J a != b #切换到JavaScript，下面的then和else若没切换则都是JavaScript then: console(\"我好厉害\"); # 可以不用 else 或者 then","s":"示例","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"#示例","p":47}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/28",[0,3.408,1,2.629,2,3.408,3,2.629,4,3.408,5,3.408]],["t/30",[6,2.813,7,3.647]],["t/32",[6,2.393,8,2.393,9,1.591,10,2.393,11,3.103,12,3.103,13,3.103,14,2.393,15,2.393,16,3.103,17,1.577]],["t/34",[8,2.056,9,1.697,10,2.056,17,1.949,18,2.665,19,2.665,20,1.354,21,1.354,22,2.665,23,2.665,24,2.145,25,3.456,26,2.145,27,1.654,28,2.056]],["t/36",[9,1.426,20,1.732,26,2.115,29,2.115,30,1.732,31,2.629]],["t/38",[3,1.233,20,2.129,30,0.813,32,1.861,33,2.241,34,2.906,35,1.599,36,1.599,37,1.599,38,1.599,39,2.241,40,1.599,41,2.413,42,2.413,43,1.599,44,1.599,45,1.599,46,1.599,47,1.233,48,2.156,49,2.009,50,2.496,51,1.599,52,1.599,53,0.813,54,1.599,55,2.413,56,1.233,57,0.993,58,1.233,59,1.861,60,1.861,61,1.599,62,2.413,63,0.993,64,1.233,65,0.993,66,1.233,67,1.599,68,1.599,69,1.599]],["t/40",[9,0.617,14,1.137,17,0.749,20,1.703,24,1.408,29,0.915,30,0.749,32,1.137,33,1.137,39,1.137,48,0.915,49,1.408,50,1.75,53,1.798,57,0.915,60,1.137,65,0.915,66,1.137,70,1.474,71,2.268,72,1.474,73,3.686,74,3.805,75,2.394,76,3.104,77,3.104,78,1.474,79,1.137,80,1.474,81,1.474,82,1.474,83,1.474,84,1.474,85,1.474,86,1.474,87,1.474,88,1.474,89,2.268,90,2.268,91,1.474,92,1.137,93,1.137,94,2.268,95,1.137,96,1.137,97,1.137,98,1.474,99,1.474]],["t/42",[9,1.403,21,1.704,26,2.081,27,2.081,28,2.586,29,2.081,30,1.704]],["t/44",[15,1.789,21,0.771,24,0.942,27,1.439,31,1.17,47,1.17,49,0.942,53,1.601,56,1.17,57,1.439,58,1.789,59,1.17,