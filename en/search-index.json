7",[1,1.198,3,1.198,8,1.198]],["t/39",[4,1.45,5,1.45]],["t/41",[8,1.45,9,1.95]],["t/45",[10,2.471]],["t/49",[11,1.95,12,1.95]],["t/51",[13,2.471]]],"invertedIndex":[["nbt",{"_index":1,"t":{"31":{"position":[[0,3]]},"37":{"position":[[0,3]]}}}],["一般",{"_index":4,"t":{"33":{"position":[[0,2]]},"39":{"position":[[0,2]]}}}],["值",{"_index":8,"t":{"37":{"position":[[3,1]]},"41":{"position":[[0,1]]}}}],["判断",{"_index":7,"t":{"35":{"position":[[2,2]]}}}],["功能",{"_index":10,"t":{"45":{"position":[[0,2]]}}}],["实际",{"_index":6,"t":{"35":{"position":[[0,2]]}}}],["形式",{"_index":5,"t":{"33":{"position":[[2,2]]},"39":{"position":[[2,2]]}}}],["支持",{"_index":11,"t":{"49":{"position":[[0,2]]}}}],["示例",{"_index":13,"t":{"51":{"position":[[0,2]]}}}],["简介",{"_index":0,"t":{"29":{"position":[[0,2]]}}}],["类型",{"_index":9,"t":{"41":{"position":[[2,2]]}}}],["节点",{"_index":2,"t":{"31":{"position":[[3,2]]}}}],["表达式",{"_index":3,"t":{"31":{"position":[[5,3]]},"37":{"position":[[4,3]]}}}],["语言",{"_index":12,"t":{"49":{"position":[[3,2]]}}}]],"pipeline":["stemmer"]}},{"documents":[{"i":28,"t":"在对物品的NBT标签进行操作时, 就会用到NBT表达式","s":"NBT表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"","p":27},{"i":30,"t":"NBT表达式分为两种: NBT节点表达式 NBT值表达式 顾名思义，对NBT标签的编辑，既需要知道在哪修改，也需要知道修改成什么。","s":"简介","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#简介","p":27},{"i":32,"t":"NBT的节点其实就是指定在哪修改","s":"NBT节点表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#nbt节点表达式","p":27},{"i":34,"t":"浅层节点: 节点名 形如 Damage CustomModelData 的是浅层节点，也就是只有一层。 深层节点: 节点I.节点II 形如 display.Name display.Name 的是深层节点。 深层节点有很多层，每层之间以 . 分割。 列表元素节点: 节点名[0] 形如 TestList[0] Enchantments[1] 的是列表元素节点。 节点名末尾以 [数字] 的形式，其中数字代表的是该列表中的元素索引。 若有一个名为 AWA 的列表 [ \"a\", \"b\", \"c\" ] 则 AWA[0] 表示列表中的第一个元素 a (没错，索引是从0开始的)","s":"一般形式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#一般形式","p":27},{"i":36,"t":"假定有这样一串NBT: Vacation: Duration: - \"5 ~ 7\" - from: \"2024/1/5\" to: \"2024/1/7\" 其中 Vacation 就是节点名，因为上面没有别的节点了，所以它是所有节点里最大的，是浅层节点。 而 Duration 则不一样，它隶属于 Vacation，是深层节点，在第二层位置，表示为 Vacation.Duration 再看 Duration 其实是个列表，第一个元素是 \"5 ~ 7\"，它的索引位置是 0 ，引用它，就需要这样的表达式 Vacation.Duration[0] 而 Duration 的第二个元素是复合的，要引用它的 from 或 to ，我们需要使用 Vacation.Duration[1].from 或者 Vacation.Duration[1].to 我们可以分别得到 \"2024/1/5\" 和 \"2024/1/7\"","s":"实际判断","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#实际判断","p":27},{"i":38,"t":"NBT的值其实就是修改成什么","s":"NBT值表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#nbt值表达式","p":27},{"i":40,"t":"一种是直接写 如 爱死你了 ，会被解析成 NBTString 类型 再如 114514 ， 会被解析成 NBTInt 类型 另一种是精确写法(精确指定类型) 精确写法必须以 : 开头 一般形式 :{V}{T} ，其中{V}代表值，{T}代表类型代号 对于集合类型，需要用 , 分割集合中的元素，如 1,1,4,5,1,4ba，其中 ba 是集合类型代号，表示 NBTByteArray 对于特殊类型，:cpd 表示 NBTCompound 类型，:list 表示 NBTList 类型 示例: NBTShort - :666s NBTFloat - :2.333f NBTIntArray - 1,2,3,4,5ia","s":"一般形式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#一般形式-1","p":27},{"i":42,"t":"允许以下类型的值 类型 代号 描述 NBTCompound c , cpd, compound 复合类型 NBTList l, list 列表类型 NBTIntArray ia 集合类型 NBTByteArray ba 集合类型 NBTLongArray la 集合类型 NBTString t 字符串 NBTInt i 整形 NBTDouble d Double NBTByte b Byte NBTLong l Long NBTFloat f Float NBTShort s Short","s":"值的类型","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#值的类型","p":27},{"i":44,"t":"基于Taboolib开发的一个多功能插件。","s":"介绍","u":"/Ratziel-Beta/en/docs/about","h":"","p":43},{"i":46,"t":"物品引擎","s":"功能","u":"/Ratziel-Beta/en/docs/about","h":"#功能","p":43},{"i":48,"t":"目前仅为设想","s":"聚合脚本语言 - ASL (Aggregate scripting language)","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"","p":47},{"i":50,"t":"MScript - 艾乐 Kether - Taboolib (实际使用的库) JavaScript - Nashorn","s":"支持的语言","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"#支持的语言","p":47},{"i":52,"t":"Example1: - $M: var a = 1 #切换到MScript,定义变量 - var b = 2 - def add(){return a + b;} # 定义函数 - $J: val out = FPool.add(); #JavaScript,执行MScript定义函数 - console(out); - $K: print &out #KetherScript，输出变量 - set a to 2 - print invoke \"add\" with [] - $K: |- # 简易表达式 set b to 2 print &b Example2: |- $M: var a = 1 var b = 2 def add(){return a + b;} $J: console(FPool.add()); $K: set a to 2 print invoke \"add\" with [] # 条件语句 Example3: - $M: var a = 6 - $M: var b = 9 - if: a == b # 默认继承上面的脚本语言，即MScript (要返回布尔值) then: a = 6 else: $K set &a to &b # 转换到Kether并且设置，不往父级传承 - try: a = b+114514 #try..catch.. 此时应该还是MScript catch: #类表达式 Test1Expection.class: @IGNORE #忽略 Test2Expection.class: print a; #MScript - if: $J a != b #切换到JavaScript，下面的then和else若没切换则都是JavaScript then: console(\"我好厉害\"); # 可以不用 else 或者 then","s":"示例","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"#示例","p":47}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/28",[0,2.393,1,2.393,2,1.591,3,2.393,4,3.103,5,3.103,6,3.103,7,2.393,8,2.393,9,3.103,10,1.577]],["t/30",[0,2.056,2,1.697,3,2.056,10,1.949,11,2.665,12,2.665,13,1.354,14,1.354,15,2.665,16,2.665,17,2.145,18,3.456,19,2.145,20,1.654,21,2.056]],["t/32",[2,1.426,13,1.732,19,2.115,22,2.115,23,1.732,24,2.629]],["t/34",[13,2.129,23,0.813,25,1.861,26,2.241,27,2.906,28,1.599,29,1.599,30,1.599,31,1.599,32,2.241,33,1.599,34,2.413,35,2.413,36,1.599,37,1.599,38,1.599,39,1.599,40,1.233,41,2.156,42,2.009,43,2.496,44,1.599,45,1.599,46,0.813,47,1.599,48,2.413,49,1.233,50,0.993,51,1.233,52,1.861,53,1.861,54,1.233,55,1.599,56,2.413,57,0.993,58,1.233,59,0.993,60,1.233,61,1.599,62,1.599,63,1.599]],["t/36",[2,0.617,7,1.137,10,0.749,13,1.703,17,1.408,22,0.915,23,0.749,25,1.137,26,1.137,32,1.137,41,0.915,42,1.408,43,1.75,46,1.798,50,0.915,53,1.137,59,0.915,60,1.137,64,1.474,65,2.268,66,1.474,67,3.686,68,3.805,69,2.394,70,3.104,71,3.104,72,1.474,73,1.137,74,1.474,75,1.474,76,1.474,77,1.474,78,1.474,79,1.474,80,1.474,81,1.474,82,1.474,83,2.268,84,2.268,85,1.474,86,1.137,87,1.137,88,2.268,89,1.137,90,1.137,91,1.137,92,1.474,93,1.474]],["t/38",[2,1.403,14,1.704,19,2.081,20,2.081,21,2.586,22,2.081,23,1.704]],["t/40",[8,1.789,14,0.771,17,0.942,20,1.439,24,1.17,40,1.17,42,0.942,46,1.601,49,1.17,50,1.439,51,1.789,52,1.17,59,1.747,69,1.17,94,2.319,95,1.517,96,1.517,97,1.517,98,1.517,99,2.319,100,1.17,101,3.035,102,1