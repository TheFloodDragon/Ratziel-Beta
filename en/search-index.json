7",[1,1.198,3,1.198,8,1.198]],["t/39",[4,1.45,5,1.45]],["t/41",[8,1.45,9,1.95]],["t/45",[10,2.471]],["t/49",[11,1.95,12,1.95]],["t/51",[13,2.471]]],"invertedIndex":[["nbt",{"_index":1,"t":{"31":{"position":[[0,3]]},"37":{"position":[[0,3]]}}}],["一般",{"_index":4,"t":{"33":{"position":[[0,2]]},"39":{"position":[[0,2]]}}}],["值",{"_index":8,"t":{"37":{"position":[[3,1]]},"41":{"position":[[0,1]]}}}],["判断",{"_index":7,"t":{"35":{"position":[[2,2]]}}}],["功能",{"_index":10,"t":{"45":{"position":[[0,2]]}}}],["实际",{"_index":6,"t":{"35":{"position":[[0,2]]}}}],["形式",{"_index":5,"t":{"33":{"position":[[2,2]]},"39":{"position":[[2,2]]}}}],["支持",{"_index":11,"t":{"49":{"position":[[0,2]]}}}],["示例",{"_index":13,"t":{"51":{"position":[[0,2]]}}}],["简介",{"_index":0,"t":{"29":{"position":[[0,2]]}}}],["类型",{"_index":9,"t":{"41":{"position":[[2,2]]}}}],["节点",{"_index":2,"t":{"31":{"position":[[3,2]]}}}],["表达式",{"_index":3,"t":{"31":{"position":[[5,3]]},"37":{"position":[[4,3]]}}}],["语言",{"_index":12,"t":{"49":{"position":[[3,2]]}}}]],"pipeline":["stemmer"]}},{"documents":[{"i":28,"t":"在对物品的NBT标签进行操作时, 就会用到NBT表达式","s":"NBT表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"","p":27},{"i":30,"t":"NBT表达式分为两种: NBT节点表达式 NBT值表达式 顾名思义，对NBT标签的编辑，既需要知道在哪修改，也需要知道修改成什么。","s":"简介","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#简介","p":27},{"i":32,"t":"NBT的节点其实就是指定在哪修改","s":"NBT节点表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#nbt节点表达式","p":27},{"i":34,"t":"浅层节点: 节点名 形如 Damage CustomModelData 的是浅层节点，也就是只有一层。 深层节点: 节点I.节点II 形如 display.Name display.Name 的是深层节点。 深层节点有很多层，每层之间以 . 分割。 列表元素节点: 节点名[0] 形如 TestList[0] Enchantments[1] 的是列表元素节点。 节点名末尾以 [数字] 的形式，其中数字代表的是该列表中的元素索引。 若有一个名为 AWA 的列表 [ \"a\", \"b\", \"c\" ] 则 AWA[0] 表示列表中的第一个元素 a (没错，索引是从0开始的)","s":"一般形式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#一般形式","p":27},{"i":36,"t":"假定有这样一串NBT: Vacation: Duration: - \"5 ~ 7\" - from: \"2024/1/5\" to: \"2024/1/7\" 其中 Vacation 就是节点名，因为上面没有别的节点了，所以它是所有节点里最大的，是浅层节点。 而 Duration 则不一样，它隶属于 Vacation，是深层节点，在第二层位置，表示为 Vacation.Duration 再看 Duration 其实是个列表，第一个元素是 \"5 ~ 7\"，它的索引位置是 0 ，引用它，就需要这样的表达式 Vacation.Duration[0] 而 Duration 的第二个元素是复合的，要引用它的 from 或 to ，我们需要使用 Vacation.Duration[1].from 或者 Vacation.Duration[1].to 我们可以分别得到 \"2024/1/5\" 和 \"2024/1/7\"","s":"实际判断","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#实际判断","p":27},{"i":38,"t":"NBT的值其实就是修改成什么","s":"NBT值表达式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#nbt值表达式","p":27},{"i":40,"t":"一种是直接写 如 爱死你了 ，会被解析成 NBTString 类型 再如 114514 ， 会被解析成 NBTInt 类型 另一种是精确写法(精确指定类型) 精确写法必须以 : 开头 一般形式 :{V}{T} ，其中{V}代表值，{T}代表类型代号 对于集合类型，需要用 , 分割集合中的元素，如 1,1,4,5,1,4ba，其中 ba 是集合类型代号，表示 NBTByteArray 对于特殊类型，:cpd 表示 NBTCompound 类型，:list 表示 NBTList 类型 示例: NBTShort - :666s NBTFloat - :2.333f NBTIntArray - 1,2,3,4,5ia","s":"一般形式","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#一般形式-1","p":27},{"i":42,"t":"允许以下类型的值 类型 代号 描述 NBTCompound c , cpd, compound 复合类型 NBTList l, list 列表类型 NBTIntArray ia 集合类型 NBTByteArray ba 集合类型 NBTLongArray la 集合类型 NBTString t 字符串 NBTInt i 整形 NBTDouble d Double NBTByte b Byte NBTLong l Long NBTFloat f Float NBTShort s Short","s":"值的类型","u":"/Ratziel-Beta/en/docs/writing/NBT节点表达式","h":"#值的类型","p":27},{"i":44,"t":"基于Taboolib开发的一个多功能插件。","s":"介绍","u":"/Ratziel-Beta/en/docs/about","h":"","p":43},{"i":46,"t":"物品引擎","s":"功能","u":"/Ratziel-Beta/en/docs/about","h":"#功能","p":43},{"i":48,"t":"目前仅为设想","s":"聚合脚本语言 - ASL (Aggregate scripting language)","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"","p":47},{"i":50,"t":"Kether - Taboolib (实际使用的库) JavaScript - Nashorn","s":"支持的语言","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"#支持的语言","p":47},{"i":52,"t":"Example1: - $M: var a = 1 #切换到MScript,定义变量 - var b = 2 - def add(){return a + b;} # 定义函数 - $J: val out = FPool.add(); #JavaScript,执行MScript定义函数 - console(out); - $K: print &out #KetherScript，输出变量 - set a to 2 - print invoke \"add\" with [] - $K: |- # 简易表达式 set b to 2 print &b Example2: |- $M: var a = 1 var b = 2 def add(){return a + b;} $J: console(FPool.add()); $K: set a to 2 print invoke \"add\" with [] # 条件语句 Example3: - $M: var a = 6 - $M: var b = 9 - if: a == b # 默认继承上面的脚本语言，即MScript (要返回布尔值) then: a = 6 else: $K set &a to &b # 转换到Kether并且设置，不往父级传承 - try: a = b+114514 #try..catch.. 此时应该还是MScript catch: #类表达式 Test1Expection.class: @IGNORE #忽略 Test2Expection.class: print a; #MScript - if: $J a != b #切换到JavaScript，下面的then和else若没切换则都是JavaScript then: console(\"我好厉害\"); # 可以不用 else 或者 then","s":"示例","u":"/Ratziel-Beta/en/docs/writing/设想-聚合脚本语言","h":"#示例","p":47}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/28",[0,2.391,1,2.391,2,1.59,3,2.391,4,3.1,5,3.1,6,3.1,7,2.391,8,2.391,9,3.1,10,1.575]],["t/30",[0,2.052,2,1.696,3,2.052,10,1.947,11,2.661,12,2.661,13,1.352,14,1.352,15,2.661,16,2.661,17,2.143,18,3.452,19,2.143,20,1.651,21,2.052]],["t/32",[2,1.425,13,1.731,19,2.114,22,2.114,23,1.731,24,2.627]],["t/34",[13,2.128,23,0.81,25,1.856,26,2.237,27,2.9,28,1.594,29,1.594,30,1.594,31,1.594,32,2.237,33,1.594,34,2.407,35,2.407,36,1.594,37,1.594,38,1.594,39,1.594,40,1.229,41,2.153,42,2.005,43,2.492,44,1.594,45,1.594,46,0.81,47,1.594,48,2.407,49,1.229,50,0.989,51,1.229,52,1.856,53,1.856,54,1.229,55,1.594,56,2.407,57,0.989,58,1.229,59,0.989,60,1.229,61,1.594,62,1.594,63,1.594]],["t/36",[2,0.614,7,1.133,10,0.746,13,1.7,17,1.404,22,0.912,23,0.746,25,1.133,26,1.133,32,1.133,41,0.912,42,1.404,43,1.745,46,1.795,50,0.912,53,1.133,59,0.912,60,1.133,64,1.469,65,2.262,66,1.469,67,3.681,68,3.8,69,2.389,70,3.098,71,3.098,72,1.469,73,1.133,74,1.469,75,1.469,76,1.469,77,1.469,78,1.469,79,1.469,80,1.469,81,1.469,82,1.469,83,2.262,84,2.262,85,1.469,86,1.133,87,1.133,88,2.262,89,1.133,90,1.133,91,1.133,92,1.469,93,1.469]],["t/38",[2,1.402,14,1.703,19,2.08,20,2.08,21,2.585,22,2.08,23,1.703]],["t/40",[8,1.784,14,0.768,17,0.938,20,1.435,24,1.166,40,1.166,42,0.938,46,1.598,49,1.166,50,1.435,51,1.784,52,1.166,59,1.743,69,1.166,94,2.312,95,1.512,96,1.512,97,1.512,98,1.512,99,2.312,100,1.166,101,3.032,102,1.166,103,1.166,104,2.808,1